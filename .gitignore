# Jekyll build output & caches
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Ruby / Bundler
# (Gemfile.lock is intentionally tracked, for reproducible builds/CI cache)
vendor/
.bundle/
*.gem

# Python
__pycache__/

# Daily-generated data — fetched fresh by scripts/fetch_*.py on every
# GitHub Actions run (see .github/workflows/pages.yml) and baked straight
# into the build artifact, never committed. Run the fetch scripts locally
# to populate these for local development.
_data/*.json

# OS cruft
.DS_Store
node_modules/

# Claude Code local config — machine/session-specific, not project source
.claude/

# Local secrets (e.g. NOTION_TOKEN for scripts/fetch_cowork.py), never committed
.env
